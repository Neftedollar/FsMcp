<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <Description>F# MCP server builder with computation expressions, typed handlers, and composable middleware</Description>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="FsMcp.Sampling" />
    <InternalsVisibleTo Include="FsMcp.Server.Tests" />
    <InternalsVisibleTo Include="FsMcp.Server.Http" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="Handlers.fs" />
    <Compile Include="Server.fs" />
    <Compile Include="DynamicServer.fs" />
    <Compile Include="Middleware.fs" />
    <Compile Include="TypedHandlers.fs" />
    <Compile Include="Streaming.fs" />
    <Compile Include="Notifications.fs" />
    <Compile Include="ToolBuilder.fs" />
    <Compile Include="ValidationMiddleware.fs" />
    <Compile Include="Telemetry.fs" />
    <Compile Include="Transport.fs" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../FsMcp.Core/FsMcp.Core.fsproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="10.0.5" />
    <PackageReference Include="ModelContextProtocol" Version="1.2.0" />
    <PackageReference Include="TypeShape" Version="10.0.0" />
    <PackageReference Include="Microsoft.Extensions.Logging.Console" Version="10.0.5" />
  </ItemGroup>

</Project>
